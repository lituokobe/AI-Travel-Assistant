# ============================================================
# AI Travel Assistant — Environment Configuration
# Copy this file to .env and fill in your API keys.
#   cp env.example .env
# ============================================================

# --- LLM Providers (DeepSeek is the primary model) ---
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Optional alternate providers (not used by default)
OPENAI_API_KEY=
OPENAI_BASE_URL=
ZHIPU_API_KEY=
ZHIPU_BASE_URL=
ALIBABA_API_KEY=
ALIBABA_BASE_URL=

# --- Web Search (Tavily) ---
TAVILY_API_KEY=your-tavily-api-key

# --- Infrastructure ---
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=mongodb_db_travel_assistant
REDIS_URI=redis://localhost:6379

# --- OpenSandbox (required — keep the real URL in .env only, not in code) ---
SANDBOX_DOMAIN=http://your-sandbox-host:8080

# --- API Server ---
API_HOST=0.0.0.0
API_PORT=8080
API_BASE_URL=http://127.0.0.1:8080

# --- Gradio UI ---
GRADIO_HOST=0.0.0.0
GRADIO_PORT=7860

# --- Demo User Defaults ---
DEFAULT_USER_ID=user-001
DEFAULT_USERNAME=Demo User
DEFAULT_PASSENGER_ID=3442 587679

# --- Agent Behaviour (api_view layer) ---
# Enable DeepSeek extended thinking — surfaced in the Thinking Process panel
ENABLE_MODEL_THINKING=true

# Optional: reuse an existing OpenSandbox instance instead of creating a new one
# SANDBOX_ID=
